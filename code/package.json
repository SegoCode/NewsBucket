		"dotenv": "^17.4.2",
		"eventsource-parser": "^3.1.0",
		"html-to-text": "^9.0.5",
		"normalize-url": "^8.0.1",
		"rss-parser": "^3.13.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0"
	}
