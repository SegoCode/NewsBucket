{
	"name": "news-wired",
	"version": "1.0.0",
	"description": "RSS/Atom feed reader",
	"type": "module",
	"scripts": {
		"start": "node js/fetch.js",
		"ai": "node js/ai.js",
		"all": "node js/fetch.js && node js/ai.js",
		"translate": "node js/translate.js",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check --write ."
	},
	"dependencies": {
